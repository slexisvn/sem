{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Sem",
  "scopeName": "source.sem",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#measureUnit" },
    { "include": "#keywords" },
    { "include": "#modifiers" },
    { "include": "#types" },
    { "include": "#aggregates" },
    { "include": "#transforms" },
    { "include": "#cardinalities" },
    { "include": "#durations" },
    { "include": "#numbers" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "match": "#.*$",
      "name": "comment.line.number-sign.sem"
    },
    "measureUnit": {
      "begin": "\\b(measure)\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*(:)",
      "beginCaptures": {
        "1": { "name": "keyword.control.sem" },
        "3": { "name": "punctuation.separator.type.sem" }
      },
      "end": "(?==)|(?=\\b(?:semi_additive|non_additive)\\b)|$",
      "patterns": [
        { "match": "[A-Za-z_][A-Za-z0-9_]*", "name": "storage.type.unit.sem" },
        { "match": "[*/]", "name": "keyword.operator.sem" }
      ]
    },
    "strings": {
      "name": "string.quoted.single.sem",
      "begin": "'",
      "end": "'",
      "patterns": [{ "match": "''", "name": "constant.character.escape.sem" }]
    },
    "keywords": {
      "match": "\\b(model|table|primary_key|timezone|fiscal_year_starts|join|on|asof|dimension|measure|metric|segment|show|by|where|having|order|asc|desc|top|assert|policy|restrict|materialize|as|funnel|steps|over|retention|periods|and|or|not|in|between|like|true|false)\\b",
      "name": "keyword.control.sem"
    },
    "modifiers": {
      "match": "\\b(distinct|semi_additive|non_additive|last|first)\\b",
      "name": "storage.modifier.sem"
    },
    "types": {
      "match": "\\b(string|number|boolean|time)\\b",
      "name": "storage.type.sem"
    },
    "aggregates": {
      "match": "\\b(sum|count|avg|min|max|median|percentile|approx_median|approx_percentile)\\b(?=\\s*\\()",
      "name": "support.function.aggregate.sem"
    },
    "transforms": {
      "match": "(?<=\\.)(mom|yoy|rolling|cumulative|share|of|mtd|qtd|ytd)\\b",
      "name": "support.function.transform.sem"
    },
    "cardinalities": {
      "match": "\\b(many_to_one|one_to_many|one_to_one|many_to_many)\\b",
      "name": "constant.language.cardinality.sem"
    },
    "durations": {
      "match": "\\b[0-9]+(d|w|m|q|y)\\b",
      "name": "constant.numeric.duration.sem"
    },
    "numbers": {
      "match": "\\b[0-9]+(\\.[0-9]+)?\\b",
      "name": "constant.numeric.sem"
    },
    "operators": {
      "match": "==|!=|<=|>=|<|>|=|\\+|-|\\*|/",
      "name": "keyword.operator.sem"
    }
  }
}
